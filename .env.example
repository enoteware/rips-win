# Remote Postgres only (dev and prod). Neon is the auth source.
# - Dev: copy from Neon dashboard or use Vercel Neon integration (auto-injects in preview/prod).
# - Prod: link Neon in Vercel project so DATABASE_URL is set automatically.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (required for admin session cookies)
# Session cookie is set using these; required for admin login and secure in production.
# Use port 3099 when running via Task "Dev Server" or npm run dev:local (avoids port conflicts).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Copy ADMIN_EMAIL and ADMIN_PASSWORD_HASH from Vercel (Project → Settings → Environment Variables) for local admin login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="run: npm run admin:hash-password -- yourpassword"

# Public env (fallback when site_settings not in DB; used by app/page.tsx)
NEXT_PUBLIC_WELCOME_CODE="rips"
NEXT_PUBLIC_RAKEBACK="10"
NEXT_PUBLIC_STAKE_US_LINK="https://stake.us/"
NEXT_PUBLIC_STAKE_COM_LINK="https://stake.com/"

# Invoi Agent API (optional; for tasks/projects via app.noteware.dev). See AGENTS.md for details.
# op read 'op://Agent Vault/Invoi Agent API/API KEY'
# INVOI_AGENT_TOKEN=
# INVOI_CLIENT_ID=175
# INVOI_PROJECT_ID=41
